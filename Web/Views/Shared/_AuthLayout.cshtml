<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — מערכת חשבוניות</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLX5UGUBeEDMdiEkvyJUElK5+Ydmf9JrwZSO" crossorigin="anonymous" />
    <style>
        body { background-color: #f0f2f5; font-family: 'Segoe UI', Tahoma, Arial, sans-serif; }
        .auth-wrapper { min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .auth-card { width: 100%; max-width: 420px; }
        .auth-title { font-size: 1.1rem; color: #6c757d; text-align: center; margin-bottom: 1.5rem; }
    </style>
</head>
<body>
    <div class="auth-wrapper px-3">
        <div class="auth-card">
            <div class="text-center mb-4">
                <h2 class="fw-bold text-primary">מערכת חשבוניות</h2>
            </div>
            @RenderBody()
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmN/Jrd+LZK2iIIsbrUUAhE7Z7" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
