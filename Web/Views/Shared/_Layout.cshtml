<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — מערכת חשבוניות</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css"
          integrity="sha384-dpuaG1suU0eT09tx5plTaGMLBsfDLX5UGUBeEDMdiEkvyJUElK5+Ydmf9JrwZSO" crossorigin="anonymous" />
    <style>
        body { background-color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Arial, sans-serif; }
        .navbar-brand { font-weight: 700; }
        .nav-link.active { font-weight: 600; }
        main { padding-top: 1.5rem; padding-bottom: 3rem; }
        .card-header { font-size: .93rem; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-md navbar-dark bg-primary shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Invoices" asp-action="Index">חשבוניות</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" ? "active" : "")"
                               asp-controller="Invoices" asp-action="Index">החשבוניות שלי</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Admin" ? "active" : "")"
                                   asp-controller="Admin" asp-action="Index">ניהול לקוחות</a>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="ChangePassword">שינוי סיסמה</a>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="nav-link btn btn-link p-0 text-white">יציאה</button>
                            </form>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <main>
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmN/Jrd+LZK2iIIsbrUUAhE7Z7" crossorigin="anonymous"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
